---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const title = 'Blog';
const description = 'Articulos sobre rutas de montaña, senderismo, viajes y aventuras al aire libre.';
---

<BaseLayout title={title} description={description}>
  <Header />
  <main class="container mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold text-stone-900 mb-4">Blog</h1>
        <p class="text-lg text-stone-600">Articulos sobre rutas de montaña, senderismo y aventuras</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {posts.map((post) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            slug={post.id}
            pubDate={post.data.pubDate}
            heroImage={post.data.heroImage}
            tags={post.data.tags}
          />
        ))}
      </div>

      {posts.length === 0 && (
        <div class="text-center py-16">
          <p class="text-stone-500">Pronto habra articulos disponibles.</p>
        </div>
      )}
    </div>
  </main>
  <Footer />
</BaseLayout>
