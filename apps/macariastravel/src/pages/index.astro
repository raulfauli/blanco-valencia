---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'));
const routes = (await getCollection('routes'));
const videos = await getCollection('videos');

const recentPosts = posts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const recentVideos = videos
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 1);

const title = 'Inicio';
const description = 'Vive y escribe tu historia - Blog de montaña, rutas y viajes de aventura';
---

<BaseLayout title={title} description={description}>
  <Header />
  <main>
    <!-- Hero Section -->
    <section class="relative bg-stone-900 text-white overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-emerald-900/40 to-stone-900/60"></div>
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32 relative z-10">
        <div class="max-w-3xl">
          <p class="text-emerald-400 font-medium mb-4">Bienvenido a</p>
          <h1 class="text-5xl md:text-7xl font-bold mb-6 leading-tight">
            Macarias<br/>Travel
          </h1>
          <p class="text-xl md:text-2xl text-stone-300 mb-8 italic">
            Vive y escribe tu historia
          </p>
          <p class="text-lg text-stone-400 mb-8 max-w-xl">
            Compartimos rutas de montaña, consejos de senderismo y experiencias de aventura en la naturaleza.
          </p>
          <div class="flex flex-wrap gap-4">
            <a
              href="/rutas"
              class="px-6 py-3 bg-emerald-600 text-white rounded-lg font-medium hover:bg-emerald-700 transition-colors"
            >
              Ver rutas
            </a>
            <a
              href="/blog"
              class="px-6 py-3 bg-white/10 text-white rounded-lg font-medium hover:bg-white/20 transition-colors backdrop-blur"
            >
              Leer blog
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Recent Articles Section -->
    {recentPosts.length > 0 && (
      <section class="container mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-3xl font-bold text-stone-900">Articulos recientes</h2>
          <a href="/blog" class="text-emerald-700 font-medium hover:text-emerald-800">
            Ver todos &rarr;
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {recentPosts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              slug={post.id}
              pubDate={post.data.pubDate}
              heroImage={post.data.heroImage}
              tags={post.data.tags}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Featured Video Section -->
    {recentVideos.length > 0 && (
      <section class="bg-stone-100 py-16">
        <div class="container mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex items-center justify-between mb-8">
            <h2 class="text-3xl font-bold text-stone-900">Video destacado</h2>
            <a href="/videos" class="text-emerald-700 font-medium hover:text-emerald-800">
              Ver todos &rarr;
            </a>
          </div>
          <div class="max-w-4xl mx-auto">
            {recentVideos.map((video) => (
              <a href={`/videos/${video.id}`} class="block group">
                <div class="relative aspect-video rounded-xl overflow-hidden bg-stone-900">
                  {video.data.heroImage || video.data.thumbnail ? (
                    <img
                      src={video.data.heroImage || video.data.thumbnail}
                      alt={video.data.title}
                      class="w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-300"
                      loading="lazy"
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center">
                      <svg class="w-20 h-20 text-stone-600" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M8 5v14l11-7z"/>
                      </svg>
                    </div>
                  )}
                  <div class="absolute inset-0 flex items-center justify-center">
                    <div class="w-20 h-20 rounded-full bg-white/20 backdrop-blur flex items-center justify-center group-hover:scale-110 transition-transform">
                      <svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M8 5v14l11-7z"/>
                      </svg>
                    </div>
                  </div>
                </div>
                <h3 class="text-2xl font-bold text-stone-900 mt-4 group-hover:text-emerald-700 transition-colors">
                  {video.data.title}
                </h3>
                <p class="text-stone-600 mt-2">{video.data.description}</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Routes Preview -->
    {routes.length > 0 && (
      <section class="container mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-3xl font-bold text-stone-900">Ultimas rutas</h2>
          <a href="/rutas" class="text-emerald-700 font-medium hover:text-emerald-800">
            Ver todas &rarr;
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {routes.slice(0, 3).map((route) => (
            <article class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition-shadow">
              <a href={`/rutas/${route.id}`} class="block">
                {route.data.heroImage && (
                  <div class="aspect-video overflow-hidden">
                    <img
                      src={route.data.heroImage}
                      alt={route.data.title}
                      class="w-full h-full object-cover"
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="p-4">
                  <div class="flex items-center gap-2 text-sm mb-2">
                    <span class="px-2 py-0.5 bg-emerald-100 text-emerald-800 rounded text-xs font-medium capitalize">
                      {route.data.difficulty}
                    </span>
                    <span class="text-stone-500">{route.data.location}</span>
                  </div>
                  <h3 class="font-bold text-stone-900 line-clamp-1">{route.data.title}</h3>
                  <p class="text-sm text-stone-500 mt-1">
                    {route.data.distance} km &middot; {route.data.elevation} m
                  </p>
                </div>
              </a>
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- CTA Section -->
    <section class="bg-emerald-700 text-white py-16">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-bold mb-4">Siguenos en redes sociales</h2>
        <p class="text-emerald-100 mb-8 max-w-2xl mx-auto">
          No te pierdas ninguna de nuestras aventuras. Siguenos en redes sociales para estar al dia.
        </p>
        <div class="flex justify-center gap-4">
          <a
            href="https://x.com/macariastravel"
            target="_blank"
            rel="noopener noreferrer"
            class="p-3 rounded-full bg-white/10 hover:bg-white/20 transition-colors"
            aria-label="Siguenos en X"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a
            href="https://instagram.com/macariastravel"
            target="_blank"
            rel="noopener noreferrer"
            class="p-3 rounded-full bg-white/10 hover:bg-white/20 transition-colors"
            aria-label="Siguenos en Instagram"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a
            href="https://youtube.com/@macariastravel"
            target="_blank"
            rel="noopener noreferrer"
            class="p-3 rounded-full bg-white/10 hover:bg-white/20 transition-colors"
            aria-label="Suscribete a YouTube"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
