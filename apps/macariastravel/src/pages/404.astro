---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Pagina no encontrada';
const description = 'La pagina que buscas no existe en nuestro sitio.';
---
<BaseLayout title={title} description={description}>
  <Header />
  <main>
    <section class="relative bg-stone-900 text-white overflow-hidden min-h-[60vh] flex items-center">
      <div class="absolute inset-0 bg-gradient-to-br from-emerald-900/40 to-stone-900/60"></div>
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-16 relative z-10 text-center">
        <p class="text-emerald-400 font-medium mb-4 text-lg">Ups!</p>
        <h1 class="text-8xl md:text-9xl font-bold mb-6 text-stone-200">404</h1>
        <p class="text-2xl md:text-3xl text-stone-300 mb-4">
          Pagina no encontrada
        </p>
        <p class="text-lg text-stone-400 mb-8 max-w-xl mx-auto">
          Lo sentimos, la pagina que buscas no existe o ha sido movida a otra ubicacion.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a
            href="/"
            class="px-6 py-3 bg-emerald-600 text-white rounded-lg font-medium hover:bg-emerald-700 transition-colors"
          >
            Volver al inicio
          </a>
          <a
            href="/blog"
            class="px-6 py-3 bg-white/10 text-white rounded-lg font-medium hover:bg-white/20 transition-colors backdrop-blur"
          >
            Ver blog
          </a>
          <a
            href="/rutas"
            class="px-6 py-3 bg-white/10 text-white rounded-lg font-medium hover:bg-white/20 transition-colors backdrop-blur"
          >
            Ver rutas
          </a>
          <a
            href="/videos"
            class="px-6 py-3 bg-white/10 text-white rounded-lg font-medium hover:bg-white/20 transition-colors backdrop-blur"
          >
            Ver videos
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
