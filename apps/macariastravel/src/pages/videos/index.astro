---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const videos = (await getCollection('videos')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const title = 'Videos';
const description = 'Videos de rutas, senderismo y aventuras al aire libre.';
---

<BaseLayout title={title} description={description}>
  <Header />
  <main class="container mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold text-stone-900 mb-4">Videos</h1>
        <p class="text-lg text-stone-600">Videos de rutas, senderismo y aventuras al aire libre</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {videos.map((video) => (
          <ArticleCard
            title={video.data.title}
            description={video.data.description}
            slug={video.id}
            pubDate={video.data.pubDate}
            heroImage={video.data.heroImage || video.data.thumbnail}
            tags={video.data.tags}
          />
        ))}
      </div>

      {videos.length === 0 && (
        <div class="text-center py-16">
          <p class="text-stone-500">Pronto habra videos disponibles.</p>
        </div>
      )}
    </div>
  </main>
  <Footer />
</BaseLayout>
