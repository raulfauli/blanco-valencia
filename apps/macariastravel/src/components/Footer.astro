---
interface SocialLink {
  platform: string;
  href: string;
  ariaLabel: string;
}

interface Sponsor {
  name: string;
  href: string;
  logo: string;
}

const socialLinks: SocialLink[] = [
  { platform: 'x', href: 'https://x.com/macariastravel', ariaLabel: 'Siguenos en X' },
  { platform: 'facebook', href: 'https://facebook.com/macariastravel', ariaLabel: 'Siguenos en Facebook' },
  { platform: 'instagram', href: 'https://instagram.com/macariastravel', ariaLabel: 'Siguenos en Instagram' },
  { platform: 'youtube', href: 'https://youtube.com/@macariastravel', ariaLabel: 'Suscribete a nuestro canal de YouTube' },
  { platform: 'spotify', href: 'https://spotify.com/macariastravel', ariaLabel: 'Escucha nuestra playlist en Spotify' },
  { platform: 'wikiloc', href: 'https://wikiloc.com/macariastravel', ariaLabel: 'Ver nuestras rutas en Wikiloc' },
  { platform: 'patreon', href: 'https://patreon.com/macariastravel', ariaLabel: 'Apoyanos en Patreon' },
];

const sponsors: Sponsor[] = [
  { name: 'Cuor3', href: 'https://cuor3.com', logo: '/assets/sponsors/cuor3.svg' },
  { name: 'Agua de Somiedo', href: 'https://aguadesomiedo.com', logo: '/assets/sponsors/agua-somiedo.svg' },
  { name: 'Las Abuelas de Sevil', href: 'https://lasabuelasdesevil.com', logo: '/assets/sponsors/abuelas-sevil.svg' },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-stone-900 text-stone-300">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center gap-3 mb-4">
          <img
            src="/assets/logo.webp"
            alt="Macarias Travel"
            class="h-10 w-auto brightness-0 invert"
            width="40"
            height="40"
          >
          <div>
            <span class="text-lg font-bold text-white">Macarias Travel</span>
          </div>
        </a>
        <p class="text-stone-400 text-sm leading-relaxed max-w-md">
          Vive y escribe tu historia. Compartimos rutas de montana, consejos de senderismo y experiencias de aventura en la naturaleza.
        </p>
      </div>

      <!-- Sponsors -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Patrocinadores</h3>
        <div class="flex flex-wrap gap-4">
          {sponsors.map(sponsor => (
            <a
              href={sponsor.href}
              target="_blank"
              rel="noopener noreferrer"
              class="block transition-opacity hover:opacity-80"
              aria-label={`Visitar ${sponsor.name}`}
            >
              <img
                src={sponsor.logo}
                alt={sponsor.name}
                class="h-10 w-auto brightness-0 invert opacity-70 hover:opacity-100"
                width="60"
                height="40"
                loading="lazy"
              >
            </a>
          ))}
        </div>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Contacto</h3>
        <a
          href="mailto:andrei.macarias@gmail.com"
          class="inline-flex items-center gap-2 text-stone-400 hover:text-white transition-colors"
          aria-label="Enviar correo electronico"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <span>andrei.macarias@gmail.com</span>
        </a>
      </div>
    </div>

    <!-- Social Links -->
    <div class="mt-8 pt-8 border-t border-stone-800">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          {socialLinks.map(link => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="p-2 rounded-lg text-stone-400 hover:text-white hover:bg-stone-800 transition-colors"
              aria-label={link.ariaLabel}
            >
              {link.platform === 'x' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              )}
              {link.platform === 'facebook' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              )}
              {link.platform === 'instagram' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              )}
              {link.platform === 'youtube' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
              )}
              {link.platform === 'spotify' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
                </svg>
              )}
              {link.platform === 'wikiloc' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0L1.5 6v12L12 24l10.5-6V6L12 0zm0 2.5l8.5 4.833v9.334L12 21.5l-8.5-4.833V7.333L12 2.5z"/>
                  <circle cx="12" cy="12" r="3"/>
                </svg>
              )}
              {link.platform === 'patreon' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M15.386.524c-4.764 0-8.64 3.876-8.64 8.64 0 4.75 3.876 8.613 8.64 8.613 4.75 0 8.614-3.864 8.614-8.613C24 4.4 20.136.524 15.386.524M.003 23.537h3.61v-9.496H.003v9.496M7.927.64H4.316c.009 1.478 0 2.98 0 4.473v15.023c0 1.44-.007 2.885-.017 4.368h3.646c.009-1.452 0-2.958 0-4.368V5.112c0-1.452 0-2.957 0-4.473z"/>
                </svg>
              )}
            </a>
          ))}
        </div>
        <p class="text-stone-500 text-sm">
          &copy; {currentYear} Macarias Travel. Todos los derechos reservados.
        </p>
      </div>
    </div>
  </div>
</footer>
