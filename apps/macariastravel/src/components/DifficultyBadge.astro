---
interface Props {
  difficulty: 'facil' | 'moderado' | 'dificil' | 'experto';
  size?: 'sm' | 'md' | 'lg';
}

const { difficulty, size = 'md' } = Astro.props;

const difficultyConfig = {
  facil: { label: 'Facil', color: 'bg-green-100 text-green-800', ring: 'ring-green-500' },
  moderado: { label: 'Moderado', color: 'bg-yellow-100 text-yellow-800', ring: 'ring-yellow-500' },
  dificil: { label: 'Dificil', color: 'bg-orange-100 text-orange-800', ring: 'ring-orange-500' },
  experto: { label: 'Experto', color: 'bg-red-100 text-red-800', ring: 'ring-red-500' },
};

const config = difficultyConfig[difficulty];

const sizeClasses = {
  sm: 'text-xs px-2 py-0.5',
  md: 'text-sm px-3 py-1',
  lg: 'text-base px-4 py-1.5',
};
---

<span
  class={`inline-flex items-center gap-1.5 rounded-full font-medium ring-1 ring-inset ${config.color} ${config.ring} ${sizeClasses[size]}`}
>
  <svg class={`${size === 'sm' ? 'w-3 h-3' : size === 'md' ? 'w-4 h-4' : 'w-5 h-5'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
  </svg>
  {config.label}
</span>
