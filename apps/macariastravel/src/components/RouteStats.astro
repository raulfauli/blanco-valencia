---
interface Props {
  distance: number;
  elevation: number;
  duration: string;
  location: string;
}

const { distance, elevation, duration, location } = Astro.props;
---

<div class="bg-stone-50 rounded-lg p-6">
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    <div class="text-center">
      <div class="flex items-center justify-center gap-2 text-stone-600 mb-1">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
        </svg>
        <span class="text-sm font-medium">Distancia</span>
      </div>
      <p class="text-2xl font-bold text-stone-900">{distance} <span class="text-sm font-normal text-stone-500">km</span></p>
    </div>

    <div class="text-center">
      <div class="flex items-center justify-center gap-2 text-stone-600 mb-1">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
        </svg>
        <span class="text-sm font-medium">Desnivel</span>
      </div>
      <p class="text-2xl font-bold text-stone-900">{elevation} <span class="text-sm font-normal text-stone-500">m</span></p>
    </div>

    <div class="text-center">
      <div class="flex items-center justify-center gap-2 text-stone-600 mb-1">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span class="text-sm font-medium">Duracion</span>
      </div>
      <p class="text-2xl font-bold text-stone-900">{duration}</p>
    </div>

    <div class="text-center">
      <div class="flex items-center justify-center gap-2 text-stone-600 mb-1">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <span class="text-sm font-medium">Ubicacion</span>
      </div>
      <p class="text-lg font-bold text-stone-900">{location}</p>
    </div>
  </div>
</div>
