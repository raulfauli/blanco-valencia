---
interface Props {
  sponsor: string;
}

const { sponsor } = Astro.props;

const sponsorConfig: Record<string, { name: string; href: string; logo: string }> = {
  'Cuor3': { name: 'Cuor3', href: 'https://cuor3.com', logo: '/assets/sponsors/cuor3.svg' },
  'Agua de Somiedo': { name: 'Agua de Somiedo', href: 'https://aguadesomiedo.com', logo: '/assets/sponsors/agua-somiedo.svg' },
  'Las Abuelas de Sevil': { name: 'Las Abuelas de Sevil', href: 'https://lasabuelasdesevil.com', logo: '/assets/sponsors/abuelas-sevil.svg' },
};

const sponsorInfo = sponsorConfig[sponsor];
---

{sponsorInfo && (
  <aside class="bg-amber-50 border border-amber-200 rounded-xl p-4 my-8">
    <p class="text-sm text-amber-800 mb-3">
      <span class="font-medium">Contenido patrocinado por:</span>
    </p>
    <a
      href={sponsorInfo.href}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block"
      aria-label={`Visitar ${sponsorInfo.name}`}
    >
      <img
        src={sponsorInfo.logo}
        alt={sponsorInfo.name}
        class="h-10 w-auto opacity-80 hover:opacity-100 transition-opacity"
        loading="lazy"
      />
    </a>
  </aside>
)}
