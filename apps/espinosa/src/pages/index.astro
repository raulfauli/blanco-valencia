---
import "~/styles/global.css";
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Equilibrados Espinosa - Mantenimiento de Ventiladores Industriales</title>
</head>
<body class="font-sans bg-gradient-to-br from-gray-50 to-gray-200">

    <!-- Header -->
    <header class="fixed top-0 w-full bg-white/95 backdrop-blur-md shadow-lg z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-col md:flex-row justify-between items-center py-4 gap-4">
                <div class="flex items-center gap-4">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 786 786" class="w-16 h-16" style="fill-rule:evenodd;clip-rule:evenodd;stroke-linejoin:round;stroke-miterlimit:2;">
                        <g id="VENTILADOR">
                            <path id="BASE" d="M669.372,263.803c16.204,40.068 25.128,83.849 25.128,129.697c0,191.239 -155.261,346.5 -346.5,346.5c-191.239,0 -346.5,-155.261 -346.5,-346.5c0,-191.239 155.261,-346.5 346.5,-346.5c29.888,0 58.897,3.792 86.572,10.922l261.783,0c3.516,-8.184 11.652,-13.922 21.118,-13.922l45.947,0c12.679,0 22.973,10.294 22.973,22.973l0,187.778c0,12.679 -10.294,22.973 -22.973,22.973l-45.947,0c-9.466,0 -17.602,-5.737 -21.118,-13.921l-26.983,0Zm-321.372,-167.803c-164.195,0 -297.5,133.305 -297.5,297.5c0,164.195 133.305,297.5 297.5,297.5c164.195,0 297.5,-133.305 297.5,-297.5c0,-164.195 -133.305,-297.5 -297.5,-297.5Z" style="fill:#f20d0d;" />
                            <g id="HELICE">
                                <animateTransform
                                    attributeName="transform"
                                    type="rotate"
                                    from="0 348 393"
                                    to="360 348 393"
                                    dur="7s"
                                    repeatCount="indefinite"/>
                                <path d="M259.073,463.807c-7.176,4.078 -34.26,18.585 -69.714,26.686c-41.492,9.48 -61.811,7.7 -77.499,-6.777c-15.688,-14.478 -18.385,-43.667 -19.167,-52.026c-0.869,-9.305 -1.484,-46.387 0.476,-64.759c1.569,-14.697 9.943,-23.569 19.873,-25.101c9.93,-1.532 18.488,2.486 31.101,10.281c35.311,21.82 73.873,29.318 90.898,31.574c0.497,-5.792 1.431,-11.46 2.768,-16.971c-9.434,-3.93 -35.962,-15.994 -62.651,-37.377c-33.216,-26.612 -44.451,-43.635 -42.86,-64.924c1.591,-21.288 22.781,-41.543 28.843,-47.35c6.749,-6.465 35.417,-29.995 51.027,-39.878c12.489,-7.906 24.644,-6.86 32.016,-0.033c7.372,6.827 9.543,16.028 11.277,30.754c4.779,40.599 22.401,75.034 31.354,90.147c4.658,-2.994 9.549,-5.656 14.64,-7.954c-2.942,-10.281 -9.895,-38.12 -9.936,-71.711c-0.053,-42.561 6.185,-61.98 23.778,-74.071c17.594,-12.091 46.655,-8.255 54.979,-7.165c9.266,1.214 45.564,8.83 63.045,14.812c13.984,4.785 20.78,14.917 20.074,24.94c-0.706,10.023 -6.52,17.477 -16.916,28.051c-29.048,29.545 -44.898,65.41 -50.894,81.555c5.439,1.913 10.688,4.229 15.713,6.912c5.677,-8.019 23.447,-31.555 50.595,-53.127c33.322,-26.478 52.416,-33.652 72.82,-27.374c20.403,6.277 35.448,31.436 39.764,38.636c4.805,8.016 21.383,41.193 27.553,58.608c4.936,13.932 1.217,25.551 -7.076,31.224c-8.294,5.672 -17.748,5.745 -32.491,4.166c-42.619,-4.565 -81.765,6.14 -97.145,11.307c1.705,4.988 3.072,10.133 4.072,15.406c7.529,-0.553 38.704,-2.137 74.838,6.025c41.515,9.379 59.07,19.763 66.963,39.598c7.892,19.835 -2.288,47.325 -5.194,55.2c-3.237,8.768 -18.705,42.476 -28.411,58.197c-7.765,12.577 -19.151,16.959 -28.768,14.05c-9.617,-2.909 -15.598,-10.231 -23.606,-22.71c-23.843,-37.16 -58.005,-61.296 -70.862,-69.372c-2.895,4.655 -6.118,9.086 -9.637,13.259c2.962,3.137 25.413,27.51 42.622,63.314c18.437,38.36 21.203,58.569 10.561,77.075c-10.642,18.505 -38.508,27.603 -46.486,30.216c-8.881,2.91 -44.906,11.725 -63.255,13.884c-14.68,1.726 -25.187,-4.474 -28.881,-13.818c-3.694,-9.344 -1.671,-18.579 3.135,-32.606c14.321,-41.795 12.004,-83.587 10.347,-98.655c-4.83,0.629 -9.756,0.954 -14.756,0.954c-0.29,0 -0.58,-0.001 -0.87,-0.004c-0.715,5.077 -5.752,37.382 -22.605,72.669c-18.343,38.406 -32.359,53.224 -53.45,56.526c-21.09,3.302 -45.641,-12.715 -52.677,-17.294c-7.833,-5.098 -37.276,-27.651 -50.456,-40.598c-10.544,-10.359 -12.295,-22.432 -7.328,-31.166c4.968,-8.734 13.433,-12.944 27.376,-17.988c40.425,-14.622 70.977,-41.519 82.457,-52.847c-4.087,-3.836 -7.89,-7.971 -11.374,-12.37Zm88.927,-127.45c-31.538,0 -57.143,25.605 -57.143,57.143c0,31.538 25.605,57.143 57.143,57.143c31.538,0 57.142,-25.605 57.142,-57.143c0,-31.538 -25.604,-57.143 -57.142,-57.143Z" style="fill:#f20d0d;" />
                            </g>
                        </g>
                    </svg>
                    <div>
                        <h1 class="text-2xl font-bold text-gray-800">Equilibrados Espinosa</h1>
                        <span class="text-sm text-primary">Mantenimiento Industrial</span>
                    </div>
                </div>
                <nav>
                    <ul class="flex flex-wrap justify-center gap-6 md:gap-8">
                        <li><a href="#servicios" class="text-gray-800 font-medium hover:text-primary transition-colors">Servicios</a></li>
                        <li><a href="#nosotros" class="text-gray-800 font-medium hover:text-primary transition-colors">Nosotros</a></li>
                        <li><a href="#contacto" class="text-gray-800 font-medium hover:text-primary transition-colors">Contacto</a></li>
                        <li><a href="#login" class="bg-primary text-white px-5 py-2 rounded-full hover:bg-red-800 transition-all hover:-translate-y-0.5">App Gestión</a></li>
                    </ul>
                </nav>
            </div>
        </div>
    </header>

    <!-- Hero Section -->
    <section id="inicio" class="mt-20 py-20 bg-gradient-to-r from-purple-600 to-purple-900 text-white relative overflow-hidden">
        <div class="absolute inset-0 bg-black/30"></div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
            <h2 class="text-4xl md:text-5xl font-bold mb-6 animate-fade-in-up">Especialistas en Equilibrado Industrial</h2>
            <p class="text-xl md:text-2xl mb-8">30 años de experiencia en mantenimiento y reparación de ventiladores industriales</p>
            <a href="#contacto" class="inline-block bg-primary text-white px-8 py-4 rounded-full font-bold text-lg hover:bg-red-800 transition-all hover:-translate-y-1 shadow-xl hover:shadow-2xl">
                Solicitar Presupuesto
            </a>
        </div>
    </section>

    <!-- Services Section -->
    <section id="servicios" class="py-20 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2 class="text-4xl font-bold text-center text-gray-800 mb-4 relative inline-block w-full">
                Nuestros Servicios
                <span class="absolute bottom-0 left-1/2 transform -translate-x-1/2 w-20 h-1 bg-primary"></span>
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mt-16">
                <!-- Service Card 1 -->
                <div class="bg-white p-8 rounded-2xl shadow-lg hover:shadow-2xl transition-all hover:-translate-y-2 border-2 border-transparent hover:border-primary">
                    <svg class="w-16 h-16 mx-auto mb-5 text-primary" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="50" cy="50" r="40" fill="none" stroke="currentColor" stroke-width="3"/>
                        <circle cx="50" cy="50" r="5" fill="currentColor"/>
                        <line x1="50" y1="15" x2="50" y2="35" stroke="currentColor" stroke-width="3"/>
                        <line x1="85" y1="50" x2="65" y2="50" stroke="currentColor" stroke-width="3"/>
                        <line x1="50" y1="85" x2="50" y2="65" stroke="currentColor" stroke-width="3"/>
                        <line x1="15" y1="50" x2="35" y2="50" stroke="currentColor" stroke-width="3"/>
                    </svg>
                    <h3 class="text-xl font-bold text-gray-800 mb-4 text-center">Equilibrado Estático y Dinámico</h3>
                    <p class="text-gray-600 text-center">Equilibrado de precisión en uno o varios planos utilizando máquinas de última generación. Servicio in situ o en nuestras instalaciones.</p>
                </div>

                <!-- Service Card 2 -->
                <div class="bg-white p-8 rounded-2xl shadow-lg hover:shadow-2xl transition-all hover:-translate-y-2 border-2 border-transparent hover:border-primary">
                    <svg class="w-16 h-16 mx-auto mb-5 text-primary" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                        <rect x="20" y="30" width="60" height="40" fill="none" stroke="currentColor" stroke-width="3"/>
                        <circle cx="35" cy="50" r="8" fill="none" stroke="currentColor" stroke-width="2"/>
                        <circle cx="65" cy="50" r="8" fill="none" stroke="currentColor" stroke-width="2"/>
                        <path d="M30 20 L70 20 L65 30 L35 30 Z" fill="currentColor"/>
                    </svg>
                    <h3 class="text-xl font-bold text-gray-800 mb-4 text-center">Reparación de Maquinaria</h3>
                    <p class="text-gray-600 text-center">Reparación integral de ventiladores industriales y maquinaria relacionada con amplia experiencia en el sector.</p>
                </div>

                <!-- Service Card 3 -->
                <div class="bg-white p-8 rounded-2xl shadow-lg hover:shadow-2xl transition-all hover:-translate-y-2 border-2 border-transparent hover:border-primary">
                    <svg class="w-16 h-16 mx-auto mb-5 text-primary" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                        <rect x="15" y="40" width="70" height="30" fill="none" stroke="currentColor" stroke-width="3"/>
                        <circle cx="30" cy="55" r="5" fill="currentColor"/>
                        <circle cx="50" cy="55" r="5" fill="currentColor"/>
                        <circle cx="70" cy="55" r="5" fill="currentColor"/>
                        <path d="M35 25 L65 25 L60 40 L40 40 Z" fill="none" stroke="currentColor" stroke-width="3"/>
                    </svg>
                    <h3 class="text-xl font-bold text-gray-800 mb-4 text-center">Fabricación Personalizada</h3>
                    <p class="text-gray-600 text-center">Fabricación de maquinaria según demanda del mercado, adaptándonos a las necesidades específicas de cada cliente.</p>
                </div>

                <!-- Service Card 4 -->
                <div class="bg-white p-8 rounded-2xl shadow-lg hover:shadow-2xl transition-all hover:-translate-y-2 border-2 border-transparent hover:border-primary">
                    <svg class="w-16 h-16 mx-auto mb-5 text-primary" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                        <rect x="20" y="15" width="60" height="70" rx="5" fill="none" stroke="currentColor" stroke-width="3"/>
                        <line x1="35" y1="30" x2="65" y2="30" stroke="currentColor" stroke-width="2"/>
                        <line x1="35" y1="45" x2="65" y2="45" stroke="currentColor" stroke-width="2"/>
                        <line x1="35" y1="60" x2="55" y2="60" stroke="currentColor" stroke-width="2"/>
                        <circle cx="50" cy="75" r="3" fill="currentColor"/>
                    </svg>
                    <h3 class="text-xl font-bold text-gray-800 mb-4 text-center">Revisión y Mantenimiento</h3>
                    <p class="text-gray-600 text-center">Aplicación de gestión para revisiones periódicas y mantenimiento preventivo, registrando temperatura, vibraciones y estado de rodamientos.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- About Section -->
    <section id="nosotros" class="py-20 bg-gradient-to-br from-gray-50 to-gray-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                <div>
                    <h3 class="text-3xl md:text-4xl font-bold text-gray-800 mb-6">Sobre Equilibrados Espinosa</h3>
                    <p class="text-lg text-gray-700 mb-5 leading-relaxed">Desde hace 30 años, Equilibrados Espinosa ha ido incrementando su ámbito de trabajo de local a internacional, así como sus servicios, calidad, seguridad y eficiencia.</p>
                    <p class="text-lg text-gray-700 mb-5 leading-relaxed">Fundada en 1996 inicialmente para solucionar problemas de equilibrados, somos punteros del sector, pudiendo equilibrar cualquier tipo de piezas con nuestras máquinas de última generación.</p>
                    <p class="text-lg text-gray-700 mb-6 leading-relaxed">El volumen de trabajo y la confianza depositada en nosotros por nuestros clientes nos ha conducido a ampliar nuestros servicios y crecer en los campos de la reparación en general y fabricación de maquinaria.</p>
                </div>
                <div class="bg-linear-to-br from-primary to-secondary text-white rounded-2xl text-center p-12">
					<h4 class="text-5xl font-bold mb-2">30+</h4>
					<p class="text-lg">Años de Experiencia</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contacto" class="py-20 bg-gray-800 text-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center">
                <h3 class="text-3xl md:text-4xl font-bold mb-6">Contacta con Nosotros</h3>
                <p class="text-xl mb-10">¿Necesitas nuestros servicios? Contáctanos para obtener un presupuesto personalizado</p>

                <div class="flex flex-wrap justify-center gap-5 mb-12">
                    <a href="tel:+34966522732" class="flex items-center gap-3 px-8 py-4 bg-white/10 backdrop-blur-md rounded-full font-semibold text-lg border-2 border-white/20 hover:bg-white hover:text-gray-800 transition-all hover:-translate-y-1 shadow-lg">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                        </svg>
                        Llamar
                    </a>
                    <a href="https://wa.me/34659013711" class="flex items-center gap-3 px-8 py-4 bg-white/10 backdrop-blur-md rounded-full font-semibold text-lg border-2 border-white/20 hover:bg-green-500 hover:border-green-500 transition-all hover:-translate-y-1 shadow-lg">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                        </svg>
                        WhatsApp
                    </a>
                    <a href="mailto:info@equilibradosespinosa.com" class="flex items-center gap-3 px-8 py-4 bg-white/10 backdrop-blur-md rounded-full font-semibold text-lg border-2 border-white/20 hover:bg-white hover:text-gray-800 transition-all hover:-translate-y-1 shadow-lg">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                            <polyline points="22,6 12,13 2,6"></polyline>
                        </svg>
                        Email
                    </a>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mt-10">
                    <div class="bg-white/10 backdrop-blur-md p-6 rounded-xl">
                        <h4 class="text-primary font-bold mb-2">Teléfono</h4>
                        <p>966 522 732</p>
                    </div>
                    <div class="bg-white/10 backdrop-blur-md p-6 rounded-xl">
                        <h4 class="text-primary font-bold mb-2">WhatsApp</h4>
                        <p>659 013 711</p>
                    </div>
                    <div class="bg-white/10 backdrop-blur-md p-6 rounded-xl">
                        <h4 class="text-primary font-bold mb-2">Email</h4>
                        <p class="break-words">info@equilibradosespinosa.com</p>
                    </div>
                    <div class="bg-white/10 backdrop-blur-md p-6 rounded-xl">
                        <h4 class="text-primary font-bold mb-2">Dirección</h4>
                        <p>Polígono Cotes Baixes, Calle B, Nº 13D<br>03804 Alcoy (Alicante)</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Login Section -->
    <section id="login" class="py-20 bg-gradient-to-r from-purple-600 to-purple-900 text-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                <div>
                    <h2 class="text-3xl md:text-4xl font-bold mb-6">Sistema de Gestión</h2>
                    <p class="text-xl mb-8 leading-relaxed">Accede a nuestra plataforma de gestión para supervisar las revisiones periódicas y el mantenimiento preventivo de tus ventiladores industriales.</p>
                    <ul class="space-y-4 text-lg">
                        <li class="flex items-start gap-3 border-b border-white/20 pb-3">
                            <span class="text-2xl">📊</span>
                            <span>Registro de temperatura de equipos</span>
                        </li>
                        <li class="flex items-start gap-3 border-b border-white/20 pb-3">
                            <span class="text-2xl">📈</span>
                            <span>Análisis de vibraciones</span>
                        </li>
                        <li class="flex items-start gap-3 border-b border-white/20 pb-3">
                            <span class="text-2xl">⚙️</span>
                            <span>Control de estado de rodamientos</span>
                        </li>
                        <li class="flex items-start gap-3 border-b border-white/20 pb-3">
                            <span class="text-2xl">📅</span>
                            <span>Programación de mantenimientos</span>
                        </li>
                        <li class="flex items-start gap-3 pb-3">
                            <span class="text-2xl">📱</span>
                            <span>Historial de revisiones</span>
                        </li>
                    </ul>
                </div>

                <div class="flex justify-center">
                    <div class="bg-white rounded-3xl p-10 shadow-2xl w-full max-w-md">
                        <h3 class="text-2xl font-bold text-gray-800 mb-8 text-center">Iniciar Sesión</h3>
                        <form id="loginForm" class="space-y-6" method="post" action="https://revisiones.equilibradosespinosa.com/admin">
                            <div>
                                <label for="email" class="block text-sm font-semibold text-gray-700 mb-2">Email</label>
                                <input type="email" id="email" name="nick" required placeholder="tu@email.com" required class="w-full px-4 py-3 border-2 border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all text-gray-800">
                            </div>
                            <div>
                                <label for="password" class="block text-sm font-semibold text-gray-700 mb-2">Contraseña</label>
                                <input type="password" id="password" name="pwd" required placeholder="Introduce tu contraseña" required class="w-full px-4 py-3 border-2 border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all text-gray-800">
                            </div>
                            <button type="submit" class="w-full bg-primary text-white py-3 rounded-lg font-bold text-lg hover:bg-red-800 transition-all hover:-translate-y-1 shadow-lg hover:shadow-xl">
                                Acceder
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white py-8 text-center">
        <div class="max-w-7xl mx-auto px-4">
            <p>&copy; 2026 Equilibrados Espinosa. Todos los derechos reservados.</p>
        </div>
    </footer>

    <script is:inline>
        // Smooth scrolling
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });
    </script>
</body>
</html>
