---
import Footer from "~/components/Footer.astro";
import Header from "~/components/Header.astro";
import Layout from "~/layouts/Layout.astro";
import "~/styles/global.css";
---

<Layout title="Equilibrados Espinosa - Mantenimiento de Ventiladores Industriales">
	<!-- Hero Section -->
	<section id="inicio" class="relative mt-24 overflow-hidden py-20 text-white">
		<div class="absolute inset-0">
			<img
				src="/assets/gallery/ventiladores/Ventailadores-01.webp"
				alt=""
				class="h-full w-full object-cover opacity-20 grayscale"
			/>
		</div>
		<div class="absolute inset-0 bg-gray-800/40"></div>
		<div class="relative z-10 mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
			<h2 class="animate-fade-in-up mb-6 text-4xl font-bold md:text-5xl">Especialistas en Equilibrado Industrial</h2>
			<p class="mb-8 text-xl md:text-2xl">
				30 años de experiencia en mantenimiento y reparación de ventiladores industriales
			</p>
			<a
				href="/trabajos"
				class="from-primary to-secondary inline-block rounded-full bg-linear-to-br px-8 py-4 text-lg font-bold text-white shadow-xl transition-all hover:-translate-y-1 hover:bg-red-800 hover:shadow-2xl"
			>
				Trabajos realizados
			</a>
		</div>
	</section>

	<!-- Services Section -->
	<section id="servicios" class="bg-white py-20">
		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
			<h2 class="relative mb-4 inline-block w-full text-center text-4xl font-bold text-gray-800">
				Precisión en <span class="text-secondary">cada proceso</span>
			</h2>

			<div class="mt-16 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4">
				<!-- Service Card 1 -->
				<div
					class="hover:border-primary rounded-2xl border-2 border-transparent bg-white p-8 shadow-lg transition-all hover:-translate-y-2 hover:shadow-2xl"
				>
					<svg class="text-secondary mx-auto mb-5 h-16 w-16" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
						<circle cx="50" cy="50" r="40" fill="none" stroke="currentColor" stroke-width="3"></circle>
						<circle cx="50" cy="50" r="5" fill="currentColor"></circle>
						<line x1="50" y1="15" x2="50" y2="35" stroke="currentColor" stroke-width="3"></line>
						<line x1="85" y1="50" x2="65" y2="50" stroke="currentColor" stroke-width="3"></line>
						<line x1="50" y1="85" x2="50" y2="65" stroke="currentColor" stroke-width="3"></line>
						<line x1="15" y1="50" x2="35" y2="50" stroke="currentColor" stroke-width="3"></line>
					</svg>
					<h3 class="mb-4 text-center text-xl font-bold text-gray-800">Equilibrado Estático y Dinámico</h3>
					<p class="text-center text-gray-600">
						Equilibrado de precisión en uno o varios planos utilizando máquinas de última generación. Servicio in situ o
						en nuestras instalaciones.
					</p>
				</div>

				<!-- Service Card 2 -->
				<div
					class="hover:border-primary rounded-2xl border-2 border-transparent bg-white p-8 shadow-lg transition-all hover:-translate-y-2 hover:shadow-2xl"
				>
					<svg class="text-secondary mx-auto mb-5 h-16 w-16" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
						<rect x="20" y="30" width="60" height="40" fill="none" stroke="currentColor" stroke-width="3"></rect>
						<circle cx="35" cy="50" r="8" fill="none" stroke="currentColor" stroke-width="2"></circle>
						<circle cx="65" cy="50" r="8" fill="none" stroke="currentColor" stroke-width="2"></circle>
						<path d="M30 20 L70 20 L65 30 L35 30 Z" fill="currentColor"></path>
					</svg>
					<h3 class="mb-4 text-center text-xl font-bold text-gray-800">Reparación de Maquinaria</h3>
					<p class="text-center text-gray-600">
						Reparación integral de ventiladores industriales y maquinaria relacionada con amplia experiencia en el
						sector.
					</p>
				</div>

				<!-- Service Card 3 -->
				<div
					class="hover:border-primary rounded-2xl border-2 border-transparent bg-white p-8 shadow-lg transition-all hover:-translate-y-2 hover:shadow-2xl"
				>
					<svg class="text-secondary mx-auto mb-5 h-16 w-16" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
						<rect x="15" y="40" width="70" height="30" fill="none" stroke="currentColor" stroke-width="3"></rect>
						<circle cx="30" cy="55" r="5" fill="currentColor"></circle>
						<circle cx="50" cy="55" r="5" fill="currentColor"></circle>
						<circle cx="70" cy="55" r="5" fill="currentColor"></circle>
						<path d="M35 25 L65 25 L60 40 L40 40 Z" fill="none" stroke="currentColor" stroke-width="3"></path>
					</svg>
					<h3 class="mb-4 text-center text-xl font-bold text-gray-800">Fabricación Personalizada</h3>
					<p class="text-center text-gray-600">
						Fabricación de maquinaria según demanda del mercado, adaptándonos a las necesidades específicas de cada
						cliente.
					</p>
				</div>

				<!-- Service Card 4 -->
				<div
					class="hover:border-primary rounded-2xl border-2 border-transparent bg-white p-8 shadow-lg transition-all hover:-translate-y-2 hover:shadow-2xl"
				>
					<svg class="text-secondary mx-auto mb-5 h-16 w-16" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
						<rect x="20" y="15" width="60" height="70" rx="5" fill="none" stroke="currentColor" stroke-width="3"></rect>
						<line x1="35" y1="30" x2="65" y2="30" stroke="currentColor" stroke-width="2"></line>
						<line x1="35" y1="45" x2="65" y2="45" stroke="currentColor" stroke-width="2"></line>
						<line x1="35" y1="60" x2="55" y2="60" stroke="currentColor" stroke-width="2"></line>
						<circle cx="50" cy="75" r="3" fill="currentColor"></circle>
					</svg>
					<h3 class="mb-4 text-center text-xl font-bold text-gray-800">Revisión y Mantenimiento</h3>
					<p class="text-center text-gray-600">
						Aplicación de gestión para revisiones periódicas y mantenimiento preventivo, registrando temperatura,
						vibraciones y estado de rodamientos.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- About Section -->
	<section id="nosotros" class="bg-linear-to-br from-gray-50 to-gray-200 py-20">
		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">
				<div>
					<h3 class="mb-6 text-3xl font-bold text-gray-800 md:text-4xl">
						Sobre <span class="text-secondary">Equilibrados Espinosa</span>
					</h3>
					<p class="mb-5 text-lg leading-relaxed text-gray-700">
						Equilibrados Espinosa ha ido incrementando su ámbito de trabajo de local a internacional, así como sus
						servicios, calidad, seguridad y eficiencia.
					</p>
					<p class="mb-5 text-lg leading-relaxed text-gray-700">
						Fundada en 1996 inicialmente para solucionar problemas de equilibrados, somos punteros del sector, pudiendo
						equilibrar cualquier tipo de piezas con nuestras máquinas de última generación.
					</p>
					<p class="mb-6 text-lg leading-relaxed text-gray-700">
						El volumen de trabajo y la confianza depositada en nosotros por nuestros clientes nos ha conducido a ampliar
						nuestros servicios y crecer en los campos de la reparación en general y fabricación de maquinaria.
					</p>
				</div>
				<div class="flex flex-col gap-5">
					<div
						class="hover:border-primary rounded-2xl border-2 border-transparent bg-white p-8 text-center shadow-lg transition-all hover:-translate-y-2 hover:shadow-2xl"
					>
						<h4 class="text-secondary mb-2 text-5xl font-bold">+30</h4>
						<p class="text-lg">Años de experiencia</p>
					</div>

					<div
						class="hover:border-primary rounded-2xl border-2 border-transparent bg-white p-8 text-center shadow-lg transition-all hover:-translate-y-2 hover:shadow-2xl"
					>
						<h4 class="text-secondary mb-2 text-5xl font-bold">+200</h4>
						<p class="text-lg">Clientes satisfechos</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Contact Section -->
	<section id="contacto" class="bg-gray-800 py-20 text-white">
		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="text-center">
				<h3 class="mb-6 text-3xl font-bold md:text-4xl">Contacta con nosotros</h3>
				<p class="mb-10 text-xl">
					¿Necesitas nuestros servicios? Contáctanos para obtener un presupuesto personalizado
				</p>

				<div class="mb-12 flex flex-wrap justify-center gap-5">
					<a
						href="tel:+34966522732"
						title="966 52 27 32"
						class="flex items-center gap-3 rounded-full border-2 border-white/20 bg-white/10 px-8 py-4 text-lg font-semibold shadow-lg backdrop-blur-md transition-all hover:-translate-y-1 hover:bg-white hover:text-gray-800"
					>
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path
								d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
							></path>
						</svg>
						Llamar
					</a>
					<a
						href="https://wa.me/34659013711"
						title="659 01 37 11"
						target="_blank"
						class="flex items-center gap-3 rounded-full border-2 border-white/20 bg-white/10 px-8 py-4 text-lg font-semibold shadow-lg backdrop-blur-md transition-all hover:-translate-y-1 hover:border-green-500 hover:bg-green-500"
					>
						<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
							<path
								d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
							></path>
						</svg>
						WhatsApp
					</a>
					<a
						href="mailto:info@equilibradosespinosa.com"
						title="info@equilibradosespinosa.com"
						class="flex items-center gap-3 rounded-full border-2 border-white/20 bg-white/10 px-8 py-4 text-lg font-semibold shadow-lg backdrop-blur-md transition-all hover:-translate-y-1 hover:bg-white hover:text-gray-800"
					>
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
							<polyline points="22,6 12,13 2,6"></polyline>
						</svg>
						Email
					</a>
					<a
						href="https://maps.app.goo.gl/V7z5GVthnkzBDKDE7"
						title="Polígono Cotes Baixes, Calle B, Nº 13D - 03804 Alcoy (Alicante)"
						target="_blank"
						class="flex items-center gap-3 rounded-full border-2 border-white/20 bg-white/10 px-8 py-4 text-lg font-semibold shadow-lg backdrop-blur-md transition-all hover:-translate-y-1 hover:bg-white hover:text-gray-800"
					>
						<svg width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
							<path
								d="M12.166 8.94c-.524 1.062-1.234 2.12-1.96 3.07A32 32 0 0 1 8 14.58a32 32 0 0 1-2.206-2.57c-.726-.95-1.436-2.008-1.96-3.07C3.304 7.867 3 6.862 3 6a5 5 0 0 1 10 0c0 .862-.305 1.867-.834 2.94M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10"
							></path>
							<path d="M8 8a2 2 0 1 1 0-4 2 2 0 0 1 0 4m0 1a3 3 0 1 0 0-6 3 3 0 0 0 0 6"></path>
						</svg>
						Alcoy (Alicante)
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Login Section -->
	<section id="login" class="bg-linear-to-r from-gray-50 to-gray-200 py-20">
		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
			<h2 class="mb-6 text-3xl font-bold md:text-4xl">
				Sistema de <span class="text-secondary">mantenimiento preventivo</span>
			</h2>
			<div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">
				<div>
					<p class="mb-8 text-xl leading-relaxed">
						Accede a nuestra plataforma de gestión para supervisar las revisiones periódicas y el mantenimiento
						preventivo de tus ventiladores industriales.
					</p>
					<ul class="space-y-4 text-lg">
						<li class="flex items-start gap-3 border-b border-white/20 pb-3">
							<span class="text-2xl">📊</span>
							<span>Registro de temperatura de equipos</span>
						</li>
						<li class="flex items-start gap-3 border-b border-white/20 pb-3">
							<span class="text-2xl">📈</span>
							<span>Análisis de vibraciones</span>
						</li>
						<li class="flex items-start gap-3 border-b border-white/20 pb-3">
							<span class="text-2xl">⚙️</span>
							<span>Control de estado de rodamientos</span>
						</li>
						<li class="flex items-start gap-3 border-b border-white/20 pb-3">
							<span class="text-2xl">📅</span>
							<span>Programación de mantenimientos</span>
						</li>
						<li class="flex items-start gap-3 pb-3">
							<span class="text-2xl">📱</span>
							<span>Historial de revisiones</span>
						</li>
					</ul>
				</div>

				<div class="flex justify-center">
					<div class="w-full max-w-md rounded-3xl bg-white p-10 shadow-2xl">
						<h3 class="mb-8 text-center text-2xl font-bold text-gray-800">Iniciar Sesión</h3>
						<form
							id="loginForm"
							class="space-y-6"
							method="post"
							action="https://revisiones.equilibradosespinosa.com/admin"
						>
							<div>
								<label for="email" class="mb-2 block text-sm font-semibold text-gray-700">Email</label>
								<input
									type="email"
									id="email"
									name="nick"
									required
									placeholder="tu@email.com"
									required
									class="focus:border-primary focus:ring-primary/10 w-full rounded-lg border-2 border-gray-200 px-4 py-3 text-gray-800 transition-all focus:ring-4 focus:outline-none"
								/>
							</div>
							<div>
								<label for="password" class="mb-2 block text-sm font-semibold text-gray-700">Contraseña</label>
								<input
									type="password"
									id="password"
									name="pwd"
									required
									placeholder="Introduce tu contraseña"
									required
									class="focus:border-primary focus:ring-primary/10 w-full rounded-lg border-2 border-gray-200 px-4 py-3 text-gray-800 transition-all focus:ring-4 focus:outline-none"
								/>
							</div>
							<button
								type="submit"
								class="bg-primary w-full rounded-lg py-3 text-lg font-bold text-white shadow-lg transition-all hover:-translate-y-1 hover:bg-red-800 hover:shadow-xl"
							>
								Acceder
							</button>
						</form>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>

<script is:inline>
	// Smooth scrolling
	document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
		anchor.addEventListener("click", function (e) {
			e.preventDefault();
			const target = document.querySelector(this.getAttribute("href"));
			if (target) {
				target.scrollIntoView({
					behavior: "smooth",
					block: "start",
				});
			}
		});
	});
</script>

<style>
	section {
		scroll-margin-top: 96px;
	}
</style>
