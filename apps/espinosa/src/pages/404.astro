---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Página No Encontrada - Equilibrados Espinosa">
	<div class="error-page">
		<div class="error-content">
			<img src="/logo.svg" alt="Espinosa Logo" class="logo" />
			<h1>404</h1>
			<p>Página no encontrada</p>
			<a href="/" class="home-link">Volver al inicio</a>
		</div>
	</div>
</Layout>

<style>
	.error-page {
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 60vh;
	}

	.error-content {
		text-align: center;
	}

	.logo {
		width: 120px;
		height: auto;
		margin-bottom: 2rem;
	}

	h1 {
		font-size: 4rem;
		font-weight: bold;
		color: #f20d0d;
		margin: 0;
	}

	p {
		font-size: 1.25rem;
		color: #666;
		margin: 1rem 0 2rem;
	}

	.home-link {
		display: inline-block;
		padding: 0.75rem 1.5rem;
		background-color: #f20d0d;
		color: white;
		text-decoration: none;
		border-radius: 4px;
		font-weight: 500;
		transition: background-color 0.2s;
	}

	.home-link:hover {
		background-color: #d00;
	}
</style>
