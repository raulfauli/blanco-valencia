---
import Layout from '../layouts/Layout.astro';
import PhotoGallery from '../components/PhotoGallery.astro';

const categories = ['equilibrados', 'instalaciones', 'maquinaria', 'ventiladores'];

const galleries = categories.map((category) => {
  const images = Array.from({ length: getImageCount(category) }, (_, i) => {
    const num = String(i + 1).padStart(2, '0');
    const filename = getFilename(category, num);
    return {
      src: `/assets/gallery/${category}/${filename}`,
      alt: `${category} ${num}`,
    };
  });
  return { category, images };
});

function getImageCount(category: string): number {
  const counts: Record<string, number> = {
    equilibrados: 10,
    instalaciones: 21,
    maquinaria: 21,
    ventiladores: 1,
  };
  return counts[category] || 0;
}

function getFilename(category: string, num: string): string {
  const prefixes: Record<string, string> = {
    equilibrados: 'Equilibrados',
    instalaciones: 'Instalaciones',
    maquinaria: 'Maquinaria',
    ventiladores: 'Ventailadores',
  };
  return `${prefixes[category]}-${num}.jpg`;
}
---

<Layout title="Galería - Espinosa">
  <h1>Galería de Trabajos</h1>
  <p class="intro">Conoce algunos de nuestros trabajos realizados en equilibrado y reparación de maquinaria industrial.</p>
  
  <div class="gallery-container">
    {galleries.map((gallery) => (
      <PhotoGallery category={gallery.category} images={gallery.images} />
    ))}
  </div>
</Layout>

<style>
  h1 {
    font-size: 2rem;
    font-weight: bold;
    margin-bottom: 0.5rem;
    color: #333;
  }

  .intro {
    color: #666;
    margin-bottom: 2rem;
  }

  .gallery-container {
    margin-top: 1rem;
  }
</style>
