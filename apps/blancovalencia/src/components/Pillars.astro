---
const baseUrl = import.meta.env.BASE_URL;

const pillars = [
	{
		step: "01",
		title: "¿QUIÉN?",
		description: "La persona y su relación consigo",
		href: `${baseUrl}quien`,
	},
	{
		step: "02",
		title: "¿QUÉ?",
		description: "La dirección, el sentido y la posibilidad",
		href: `${baseUrl}que`,
	},
	{
		step: "03",
		title: "¿CÓMO?",
		description: "El acompañamiento que lo hace sostenible",
		href: `${baseUrl}como`,
	},
	{
		step: "04",
		title: "¿CUÁNDO?",
		description: "El momento, la evolución y la claridad",
		href: `${baseUrl}cuando`,
	},
];
---

<div class="mb-16">
	<div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
		{
			pillars.map((pillar) => (
				<a
					href={pillar.href}
					class="block bg-white/50 p-8 transition-all hover:-translate-y-1 hover:shadow-lg"
				>
					<div class="mb-4 text-4xl font-black text-gray-300">{pillar.step}</div>
					<h3 class="mb-3 text-lg font-bold">{pillar.title}</h3>
					<p class="text-sm leading-relaxed text-gray-600">{pillar.description}</p>
				</a>
			))
		}
	</div>
</div>
