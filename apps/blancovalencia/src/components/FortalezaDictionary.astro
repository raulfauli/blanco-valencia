---
import { getCollection } from "astro:content";

const fortalezas = (await getCollection("fortalezas")).sort((a, b) =>
	a.data.title.localeCompare(b.data.title, "es"),
);
const currentPath = Astro.url.pathname;
const baseUrl = import.meta.env.BASE_URL;
---

<section class="mt-16" id="diccionario">
	<h3 class="mb-8 text-2xl font-bold tracking-wide uppercase">Diccionario de Fortalezas</h3>
	<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
		{
			fortalezas.map((fortaleza) => {
				const href = `${baseUrl}fortalezas/${fortaleza.id}`;
				const isActive = currentPath.replace(/\/$/, "") === href.replace(/\/$/, "");

				return (
					<a
						href={href}
						class={`block p-6 transition-all hover:-translate-y-1 hover:shadow-lg ${
							isActive ? "bg-black text-[#e4e2dd]" : "bg-white/50 hover:bg-white"
						}`}
					>
						<div class={`mb-1 text-base font-bold uppercase ${isActive ? "text-[#e4e2dd]" : ""}`}>
							{fortaleza.data.title}
						</div>
						<div class={`text-sm leading-relaxed ${isActive ? "text-[#e4e2dd]/70" : "text-gray-600"}`}>
							{fortaleza.data.description}
						</div>
					</a>
				);
			})
		}
	</div>
</section>
