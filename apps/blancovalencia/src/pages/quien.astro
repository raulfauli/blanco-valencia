---
import type { CollectionEntry } from "astro:content";
import { getCollection, render } from "astro:content";
import HeaderBar from "~/components/HeaderBar.astro";
import Pillars from "~/components/Pillars.astro";
import Layout from "~/layouts/Layout.astro";

const allContent = await getCollection("pages");
const entry: CollectionEntry<"pages"> | undefined = allContent.find((e) => e.id === "1-quien");

if (!entry) {
	throw new Error("No se encontró el contenido de 1-quien");
}

const { Content } = await render(entry);
---

<Layout title="Quién | Blanco Valencia" description="La persona y su relación consigo misma">
	<HeaderBar />

	<div class="container m-auto my-16 px-6">
		<div class="mx-auto max-w-4xl">
			<div class="mb-16 text-center">
				<p class="mb-4 text-sm tracking-widest text-gray-600 uppercase">La metodología</p>
				<h1 class="mb-6 text-5xl font-black uppercase sm:text-6xl">¿Quién?</h1>
				<p class="mx-auto max-w-2xl text-lg leading-relaxed text-gray-700">La persona y su relación consigo misma</p>
			</div>

			<Pillars />

			<article class="prose lg:prose-xl max-w-none">
				<Content />
			</article>
		</div>
	</div>
</Layout>
