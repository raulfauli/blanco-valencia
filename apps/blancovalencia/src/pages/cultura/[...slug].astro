---
import { Image } from "astro:assets";
import { type CollectionEntry, getCollection, render } from "astro:content";
import HeaderBar from "../../components/HeaderBar.astro";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
	const posts = await getCollection("cultura");
	const images = import.meta.glob("../../content/cultura/*.jpg", { eager: true });
	const postsWithImages = posts.map((post) => ({
		...post,
		data: {
			...post.data,
			image: images[`../../content/cultura/${post.id}.jpg`]?.default,
		},
	}));

	const sortedPosts = postsWithImages.sort(
		(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
	);

	return postsWithImages.map((post) => {
		const relatedPosts = sortedPosts
			.filter((p) => p.id !== post.id)
			.slice(0, 3);

		return {
			params: { slug: post.id },
			props: { post, relatedPosts },
		};
	});
}

type Props = {
	post: CollectionEntry<"cultura">;
	relatedPosts: CollectionEntry<"cultura">[];
};

const { post, relatedPosts } = Astro.props;
const { Content } = await render(post);

const baseUrl = import.meta.env.BASE_URL;
---

<Layout title={`${post.data.title} | Blanco Valencia`}>
	<HeaderBar />
	<div class="container m-auto my-16 px-6">
		<div class="mx-auto max-w-4xl">
			<div class="mb-16 text-center">
				<p class="mb-4 text-sm tracking-widest text-gray-600 uppercase">Cultura Online</p>
				<h1 class="mb-6 text-6xl font-black uppercase sm:text-7xl">{post.data.title}</h1>
				<p class="mx-auto max-w-2xl text-lg leading-relaxed text-gray-700">
					{post.data.description}
				</p>
				<div class="mt-8 inline-block border-y-2 border-black px-6 py-2 text-sm font-bold tracking-widest uppercase">
					{post.data.pubDate.toLocaleDateString("es-ES", { day: "numeric", month: "long", year: "numeric" })}
				</div>
			</div>

			<Image src={post.data.image} alt={post.data.title} class="mb-12 h-[400px] w-full object-cover contrast-110" />

			<article class="prose prose-lg mx-auto max-w-3xl text-justify">
				<Content />
			</article>
		</div>

		<!-- Related Articles -->
		<div class="mx-auto mt-24 max-w-6xl">
			<h2 class="mb-12 text-center text-3xl font-black uppercase">Artículos relacionados</h2>
			<div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
				{
					relatedPosts.map((relatedPost) => (
						<div class="relative overflow-hidden bg-white/30 transition-transform hover:-translate-y-1">
							<Image
								src={relatedPost.data.image}
								alt={relatedPost.data.title}
								class="h-[250px] w-full object-cover"
							/>
							<div class="p-8">
								<div class="mb-4 text-xs font-bold tracking-wider text-gray-600">
									{relatedPost.data.pubDate
										.toLocaleDateString("es-ES", {
											day: "numeric",
											month: "short",
											year: "numeric",
										})
										.toUpperCase()}
								</div>
								<h3 class="mb-4 text-[22px] leading-tight font-bold">
									<a
										href={`${baseUrl}cultura/${relatedPost.id}/`}
										class="stretched-link transition-opacity hover:opacity-60"
									>
										{relatedPost.data.title}
									</a>
								</h3>
								<p class="text-[15px] leading-relaxed text-gray-700">{relatedPost.data.description}</p>
							</div>
						</div>
					))
				}
			</div>
		</div>
	</div>
</Layout>
