---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { getCollection, render } from "astro:content";
import HeaderBar from "~/components/HeaderBar.astro";
import propositoBg from "~/content/pages/proposito-real.jpg";
import Layout from "~/layouts/Layout.astro";

const allContent = await getCollection("pages");
const entry: CollectionEntry<"pages"> | undefined = allContent.find((e) => e.id === "proposito-real");

if (!entry) {
	throw new Error("No se encontró el contenido de proposito-real");
}

const { Content } = await render(entry);
---

<Layout title="Propósito real | Blanco Valencia" description="Nuestro propósito real">
	<HeaderBar />

	<div class="container m-auto my-16 px-6">
		<div class="mx-auto max-w-4xl">
			<div class="mb-16 text-center">
				<p class="mb-4 text-sm tracking-widest text-gray-600 uppercase">Nosotros</p>
				<h1 class="mb-6 text-5xl font-black uppercase sm:text-6xl">Propósito real</h1>
			</div>

			<div class="mb-16">
				<Image src={propositoBg} alt="Propósito real" class="h-[400px] w-full object-cover" />
			</div>

			<article class="prose lg:prose-xl max-w-none">
				<Content />
			</article>
		</div>
	</div>
</Layout>
