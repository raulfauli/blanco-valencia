---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { getCollection, render } from "astro:content";
import HeaderBar from "~/components/HeaderBar.astro";
import propositoBg from "~/content/pages/proposito-real.jpg";
import Layout from "~/layouts/Layout.astro";

const allContent = await getCollection("pages");
const entry: CollectionEntry<"pages"> | undefined = allContent.find((e) => e.id === "proposito-real");

if (!entry) {
	throw new Error("No se encontró el contenido de proposito-real");
}

const { Content, headings } = await render(entry);
---

<Layout>
	<HeaderBar />

	<div class="relative flex h-[70vh] items-center justify-center overflow-hidden">
		<!-- Background Image -->
		<Image src={propositoBg} alt="Propósito real" class="absolute inset-0 h-full w-full object-cover" />

		<!-- Overlay -->
		<div class="absolute inset-0 bg-black/50"></div>

		<!-- Title Over Image -->
		<div class="relative z-10 px-10 text-center">
			<h1
				class="mb-6 text-8xl leading-none font-black tracking-tight text-white uppercase sm:text-5xl md:text-6xl lg:text-7xl"
			>
				Propósito real
			</h1>
			<div class="mx-auto h-1 w-32 bg-white"></div>
		</div>
	</div>

	<div class="container">
		<div class="grid gap-8 md:grid-cols-3">
			<article class="prose lg:prose-xl md:col-span-2">
				<Content />
			</article>

			<aside class="md:col-span-1">
				<nav class="sticky top-20 self-start">
					<ul class="text-sm space-y-2">
						{
							headings.map((h) => (
								<li class={`ml-${(h.depth - 2) * 4}`}>
									<a href={`#${h.slug}`}>{h.text}</a>
								</li>
							))
						}
					</ul>
				</nav>
			</aside>
		</div>
	</div>
</Layout>
