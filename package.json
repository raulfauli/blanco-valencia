{
	"private": true,
	"workspaces": [
		"apps/*"
	],
	"type": "module",
	"scripts": {
		"blancovalencia:astro": "bun run --cwd apps/blancovalencia astro",
		"blancovalencia:deploy": "bun run --cwd apps/blancovalencia deploy",
		"espinosa:astro": "bun run --cwd apps/espinosa astro",
		"fayu:start": "bun run --cwd apps/fayudev start",
		"fayu:deploy": "bun run --cwd apps/fayudev deploy"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"prettier": "^3.8.1",
		"prettier-plugin-astro": "^0.14.1",
		"prettier-plugin-tailwindcss": "^0.7.2"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"packageManager": "bun@1.3.9"
}
